{
  // Attach VSCode to the running VEHU container.
  // Prerequisites:
  //   1. docker-compose up -d
  //   2. bash scripts/setup-container.sh
  //   3. Open this folder in VSCode → "Reopen in Container"
  "name": "VEHU FileMan Browser",

  // Attach to the already-running container (not build a new one)
  "dockerComposeFile": "../docker-compose.yml",
  "service": "vehu",
  "workspaceFolder": "/opt/vista-fm-browser",

  // VSCode extensions to install inside the container
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "njpwerner.autodocstring",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/vista-fm-browser/.venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["-v", "--tb=short"],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Run after VSCode attaches — install Python deps if not already done
  "postAttachCommand": "cd /opt/vista-fm-browser && pip install -e '.[dev]' -q"
}
